# PROXIMUS Configuration
# Copy this to .env and fill in your values

# =============================================================================
# LiveKit Configuration
# =============================================================================
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_SIP_URI=your-project.sip.livekit.cloud
LIVEKIT_API_SECRET=your-api-secret

# =============================================================================
# SIP Provider: "telnyx" (default) or "twilio"
# =============================================================================
SIP_PROVIDER=telnyx

# =============================================================================
# Telnyx Configuration (used when SIP_PROVIDER=telnyx)
# =============================================================================
TELNYX_API_KEY=your-telnyx-api-key
TELNYX_SIP_URI=your-livekit-sip-uri.sip.livekit.cloud
TELNYX_SIP_USERNAME=your-sip-username
TELNYX_SIP_PASSWORD=your-sip-password
TELNYX_PHONE_NUMBER=+1234567890
# Credential connection ID — only needed for dynamic caller ID (ANI) override on outbound calls
TELNYX_CREDENTIAL_CONNECTION_ID=your-credential-connection-id

# =============================================================================
# Twilio Configuration (used when SIP_PROVIDER=twilio)
# =============================================================================
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890
# TWILIO_TERMINATION_URI=your-trunk.pstn.twilio.com
# SIP Credential List credentials (Twilio Console: Elastic SIP Trunking -> your trunk
# -> Authentication -> Credential Lists). NOT the same as Account SID / Auth Token.
# TWILIO_SIP_USERNAME=your-credential-list-username
# TWILIO_SIP_PASSWORD=your-credential-list-password

# =============================================================================
# Agent Configuration
# =============================================================================
AGENT_NAME=proximus-agent
ROOM_PREFIX=proximus-call-
# LiveKit SIP outbound trunk ID — required for making outbound calls
OUTBOUND_TRUNK_ID=your-outbound-trunk-id

# =============================================================================
# AI Providers (at least one required)
# =============================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
AI_PROVIDER=anthropic
# LLM model per provider. Default is a low-latency model for short voice turns.
# For higher quality on Anthropic, use claude-sonnet-5.
ANTHROPIC_MODEL=claude-haiku-4-5
OPENAI_MODEL=gpt-4o

# =============================================================================
# Speech Services
# =============================================================================
DEEPGRAM_API_KEY=your-deepgram-api-key
CARTESIA_API_KEY=your-cartesia-api-key

# =============================================================================
# Application Settings
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
# API authentication: when set, every non-public route requires an
# `X-API-Key: <this value>` header. Leave empty for local dev, but SET IT
# before exposing the server — outbound calls cost real money.
API_KEY=
# Comma-separated allowed CORS origins for the web dashboard.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Max outbound calls per rolling minute (0 disables the limit).
OUTBOUND_RATE_LIMIT_PER_MIN=10
LOG_LEVEL=INFO
